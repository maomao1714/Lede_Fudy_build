config global 'global'
	option enabled '0'
	option program 'rtp2httpd'

config msd 'msd'
	option interface 'eth0'
	option port '4022'
	option source_prefix ''
	option buffer '4096'
	option extra_args ''

config rtp2httpd 'rtp2httpd'
	option http_addr '0.0.0.0'
	option http_port '8080'
	option interface 'eth0'
	option buffer '65536'
	option playlist '/etc/rtp2httpd/channels.m3u'
	option udpxy_compat '0'
	option max_clients '10'
	option source_ip ''
	option log_level 'warning'
	option url_prefix ''
	option extra_args ''
