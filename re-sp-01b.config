

# ── 设备 TARGET ──────────────────────────────────────
CONFIG_MODULES=y
CONFIG_HAVE_DOT_CONFIG=y
CONFIG_HOST_OS_LINUX=y
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_jdcloud_re-sp-01b=y
CONFIG_HAS_SUBTARGETS=y
CONFIG_HAS_DEVICES=y
CONFIG_TARGET_BOARD="ramips"
CONFIG_TARGET_SUBTARGET="mt7621"
CONFIG_TARGET_PROFILE="DEVICE_jdcloud_re-sp-01b"
CONFIG_TARGET_ARCH_PACKAGES="mipsel_24kc"
CONFIG_DEFAULT_TARGET_OPTIMIZATION="-Os -pipe -mno-branch-likely -mips32r2 -mtune=24kc"
CONFIG_CPU_TYPE="24kc"
# ── 内核 ──────────────────────────────────────────────
CONFIG_TESTING_KERNEL=y
CONFIG_LINUX_6_6=y

# ── 分区 ──────────────────────────────────────────────
CONFIG_TARGET_ROOTFS_PARTSIZE=448
CONFIG_TARGET_ROOTFS_SQUASHFS=y

# ── 基础功能 ──────────────────────────────────────────
CONFIG_IPV6=y

# ── LuCI ─────────────────────────────────────────────
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-lib-ipkg=y
CONFIG_PACKAGE_luci-light=y

# ── 主题 ──────────────────────────────────────────────
CONFIG_PACKAGE_luci-theme-design=y
CONFIG_PACKAGE_luci-app-design-config=y

CONFIG_LUCI_LANG_zh_Hans=y

# ── WiFi 驱动（MT7981 Filogic 平台）──────────────────
# 注意：RE-SP-01B 的实际 WiFi 芯片型号以设备档案为准
# 如果 LEDE 不支持该设备，这里驱动可能也需要调整
CONFIG_PACKAGE_kmod-mt7915e=y
CONFIG_PACKAGE_kmod-mt7981-firmware=y
CONFIG_PACKAGE_mt7981-wo-firmware=y

# ── 无线加密（轻量版）────────────────────────────────
CONFIG_PACKAGE_wpad-basic-mbedtls=y

# ── 其余插件按需保留（256MB 建议精简）────────────────

# openvpn
CONFIG_PACKAGE_luci-app-openvpn-server=y
CONFIG_PACKAGE_luci-i18n-openvpn-server-zh-cn=y
CONFIG_PACKAGE_openvpn-openssl=y
CONFIG_OPENVPN_openssl_ENABLE_LZO=y
CONFIG_OPENVPN_openssl_ENABLE_LZ4=y
CONFIG_OPENVPN_openssl_ENABLE_FRAGMENT=y
CONFIG_OPENVPN_openssl_ENABLE_MULTIHOME=y
CONFIG_OPENVPN_openssl_ENABLE_SMALL=y
CONFIG_PACKAGE_openvpn-easy-rsa=y
# QModem
#
CONFIG_PACKAGE_qmodem=y
CONFIG_PACKAGE_luci-app-qmodem=y
CONFIG_PACKAGE_luci-app-qmodem-sms=y
CONFIG_PACKAGE_luci-app-qmodem-ttl=y

CONFIG_PACKAGE_quectel-CM-5G-M=y

CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=y
CONFIG_PACKAGE_kmod-usb-net-cdc-mbim=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ncm=y

CONFIG_PACKAGE_kmod-usb-serial=y
CONFIG_PACKAGE_kmod-usb-serial-option=y
CONFIG_PACKAGE_kmod-usb-serial-qualcomm=y
CONFIG_PACKAGE_kmod-usb-serial-wwan=y

CONFIG_PACKAGE_kmod-usb-wdm=y

CONFIG_PACKAGE_kmod-qmi_wwan_f=y
CONFIG_PACKAGE_kmod-qmi_wwan_q=y
CONFIG_PACKAGE_kmod-qmi_wwan_s=y

#
# Lucky
#
CONFIG_PACKAGE_lucky=y
CONFIG_PACKAGE_luci-app-lucky=y

#
# IPTV（MSD）
CONFIG_PACKAGE_msd_lite=y
CONFIG_PACKAGE_rtp2httpd=y
CONFIG_PACKAGE_luci-app-iptv-manager=y
#CONFIG_PACKAGE_luci-app-msd_lite=y
#CONFIG_PACKAGE_luci-app-rtp2httpd=y

# Samba（经典版）
#
CONFIG_PACKAGE_luci-app-samba=y
CONFIG_PACKAGE_samba36-server=y

#
# USB 存储
#
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y

#
# 文件系统
#
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y

CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_blockd=y


# 网络优化
#
CONFIG_PACKAGE_kmod-tcp-bbr=y
CONFIG_PACKAGE_iptables-mod-fullconenat=y
CONFIG_PACKAGE_kmod-ipt-offload=y

#
# Turbo ACC
#
CONFIG_PACKAGE_luci-app-turboacc=y

#
# UPnP
#
CONFIG_PACKAGE_miniupnpd=y
CONFIG_PACKAGE_luci-app-upnp=y

#
# WOL
#
CONFIG_PACKAGE_wol=y
CONFIG_PACKAGE_luci-app-wol=y

#
# CPU调频
#
#CONFIG_PACKAGE_luci-app-cpufreq=y

#
# 常用工具
#
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_jq=y
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_lsblk=y
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_coreutils=y
CONFIG_PACKAGE_coreutils-nohup=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_openssl-util=y

#
# 网络工具
#
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_tcpdump=y

#
# DNS
#
CONFIG_PACKAGE_dnsmasq-full=y

#
# 中文支持
#
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-dockerman-zh-cn=y
CONFIG_PACKAGE_luci-i18n-samba-zh-cn=y
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=y
CONFIG_PACKAGE_luci-i18n-wol-zh-cn=y
CONFIG_PACKAGE_luci-i18n-cpufreq-zh-cn=y

#
# Busybox 优化
#
CONFIG_BUSYBOX_CUSTOM=y

#
# 性能优化
#
CONFIG_PACKAGE_irqbalance=y
CONFIG_PACKAGE_kmod-sched-core=y




#CONFIG_PACKAGE_luci-app-wireguard=y
CONFIG_PACKAGE_luci-app-vlmcsd=y
#CONFIG_PACKAGE_luci-app-openclaw=y
#CONFIG_PACKAGE_luci-app-qbittorrent=y
