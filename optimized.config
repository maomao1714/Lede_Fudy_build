# =====================================================
# WH3000 编译配置 - 基于原始 LEDE makedefconfig 精简
# 原则：WiFi/驱动/系统包完整保留，只删冗余/冲突项
# 内核：Linux 6.6 (LEDE mediatek filogic 默认)
# =====================================================

# --- 目标平台（不可更改）---
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_huasifei_wh3000-emmc=y
CONFIG_TARGET_ARCH_PACKAGES="aarch64_cortex-a53"
CONFIG_CPU_TYPE="cortex-a53"
CONFIG_LINUX_6_6=y

# --- 固件格式 ---
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_SQUASHFS_BLOCK_SIZE=256
CONFIG_TARGET_ROOTFS_INITRAMFS=y
CONFIG_TARGET_INITRAMFS_COMPRESSION_XZ=y
CONFIG_TARGET_ROOTFS_INITRAMFS_SEPARATE=y
CONFIG_TARGET_ROOTFS_PARTSIZE=448

# --- 编译优化 ---
CONFIG_TARGET_OPTIMIZATION="-Os -pipe -mcpu=cortex-a53"
CONFIG_EXTRA_OPTIMIZATION="-fno-caller-saves -fno-plt"
CONFIG_USE_SSTRIP=y
CONFIG_USE_MUSL=y
CONFIG_GCC_VERSION="13.3.0"
CONFIG_LIBC="musl"
CONFIG_IPV6=y

# --- 安全选项 ---
CONFIG_PKG_CHECK_FORMAT_SECURITY=y
CONFIG_PKG_ASLR_PIE_REGULAR=y
CONFIG_PKG_CC_STACKPROTECTOR_REGULAR=y
CONFIG_PKG_FORTIFY_SOURCE_1=y
CONFIG_PKG_RELRO_FULL=y
CONFIG_SIGNED_PACKAGES=y
CONFIG_SIGNATURE_CHECK=y

# =====================================================
# FEEDS 软件源
# =====================================================
CONFIG_FEED_packages=y
CONFIG_FEED_luci=y
CONFIG_FEED_routing=y
CONFIG_FEED_qmodem=y
CONFIG_FEED_lucky=y
CONFIG_FEED_rtp2httpd=y

# =====================================================
# 基础系统
# =====================================================
CONFIG_PACKAGE_base-files=y
CONFIG_PACKAGE_busybox=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_openwrt-keyring=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_dnsmasq_full_dhcp=y
CONFIG_PACKAGE_dnsmasq_full_dhcpv6=y
CONFIG_PACKAGE_dnsmasq_full_ipset=y
CONFIG_PACKAGE_dnsmasq_full_tftp=y
CONFIG_PACKAGE_dropbear=y
CONFIG_PACKAGE_firewall=y
CONFIG_PACKAGE_fstools=y
CONFIG_PACKAGE_fwtool=y
CONFIG_PACKAGE_getrandom=y
CONFIG_PACKAGE_jsonfilter=y
CONFIG_PACKAGE_logd=y
CONFIG_PACKAGE_mtd=y
CONFIG_PACKAGE_netifd=y
CONFIG_PACKAGE_opkg=y
CONFIG_PACKAGE_procd=y
CONFIG_PACKAGE_procd-ujail=y
CONFIG_PACKAGE_procd-seccomp=y
CONFIG_PACKAGE_resolveip=y
CONFIG_PACKAGE_uci=y
CONFIG_PACKAGE_urandom-seed=y
CONFIG_PACKAGE_urngd=y
CONFIG_PACKAGE_usign=y
CONFIG_PACKAGE_ubox=y
CONFIG_PACKAGE_ubus=y
CONFIG_PACKAGE_ubusd=y
CONFIG_PACKAGE_rpcd=y
CONFIG_PACKAGE_rpcd-mod-rrdns=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_uboot-envtools=y
CONFIG_PACKAGE_libc=y
CONFIG_PACKAGE_libgcc=y
CONFIG_PACKAGE_libpthread=y
CONFIG_PACKAGE_librt=y
CONFIG_PACKAGE_libstdcpp=y
CONFIG_PACKAGE_libatomic=y

# =====================================================
# ★★★ WiFi 驱动（完整，严格对应 MT7981 / WH3000）★★★
#
# WH3000 硬件：MT7981B SoC + MT7976CN 射频 + RTL8221B PHY
# 驱动框架：开源 mt76（不使用 MediaTek 私有闭源驱动）
#
# 首次刷机 WiFi 不出现的根因：
# mt7981-wo-firmware（Wireless Offload 固件）与 netifd
# 的启动时序竞争，netifd 先就绪时 radio 初始化失败。
# 修复方案在 diy-part2.sh 的 uci-defaults 脚本中处理。
# =====================================================

# --- 驱动能力声明（缺少会导致 AX/AC 功能静默关闭）---
CONFIG_DRIVER_11AC_SUPPORT=y
CONFIG_DRIVER_11AX_SUPPORT=y

# --- mac80211 / cfg80211 基础框架 ---
CONFIG_PACKAGE_kmod-cfg80211=y
CONFIG_PACKAGE_kmod-mac80211=y
CONFIG_PACKAGE_MAC80211_MESH=y
CONFIG_PACKAGE_MAC80211_DEBUGFS=y

# --- mt76 驱动完整链（每一层缺失都会导致 WiFi 不工作）---
# 基础层
CONFIG_PACKAGE_kmod-mt76-core=y
# connac 公共层（MT7915/MT7921/MT7981 共用）
CONFIG_PACKAGE_kmod-mt76-connac=y
# MT7915e 驱动主体（MT7981 使用此驱动，名称历史原因）
CONFIG_PACKAGE_kmod-mt7915e=y

# --- MT7981 专用固件文件 ---
# kmod-mt7981-firmware：包含 eeprom/cal 固件，射频初始化必须
CONFIG_PACKAGE_kmod-mt7981-firmware=y
# mt7981-wo-firmware：Wireless Offload 固件，缺少会导致
# 首次启动 WiFi 不出现（需重启才恢复）
CONFIG_PACKAGE_mt7981-wo-firmware=y

# --- 无线监管数据库（缺少会导致 radio 不广播信号）---
CONFIG_PACKAGE_wireless-regdb=y

# --- wpad：AP 守护进程（缺少无法建立 WiFi 热点）---
# wpad-openssl 版本支持 WPA2/WPA3/802.11r/802.11w
CONFIG_PACKAGE_wpad-openssl=y
CONFIG_PACKAGE_hostapd-common=y

# --- WiFi 管理工具 ---
# 注意：只保留 iw-full，删除 iw（两者文件冲突）
CONFIG_PACKAGE_iw-full=y
CONFIG_PACKAGE_iwinfo=y
CONFIG_PACKAGE_libiwinfo=y
CONFIG_PACKAGE_libiwinfo-data=y
CONFIG_PACKAGE_libiwinfo-lua=y

# --- wifi-scripts：netifd WiFi 脚本（LuCI 控制 radio 必须）---
# 缺少此包时 LuCI 无线页面显示空白，无法配置 WiFi
CONFIG_PACKAGE_wifi-scripts=y

# --- ucode WiFi 相关模块（LuCI 无线界面运行时依赖）---
CONFIG_PACKAGE_ucode=y
CONFIG_PACKAGE_ucode-mod-nl80211=y
CONFIG_PACKAGE_ucode-mod-fs=y
CONFIG_PACKAGE_ucode-mod-rtnl=y
CONFIG_PACKAGE_ucode-mod-ubus=y
CONFIG_PACKAGE_ucode-mod-uloop=y
CONFIG_PACKAGE_libucode=y

# =====================================================
# LuCI Web 管理界面
# =====================================================
CONFIG_PACKAGE_uhttpd=y
CONFIG_PACKAGE_uhttpd-mod-ubus=y
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-lua-runtime=y
CONFIG_PACKAGE_luci-lib-ip=y
CONFIG_PACKAGE_luci-lib-jsonc=y
CONFIG_PACKAGE_luci-lib-nixio=y
CONFIG_PACKAGE_luci-lib-fs=y
CONFIG_PACKAGE_luci-proto-ipv6=y
CONFIG_PACKAGE_luci-proto-ppp=y
CONFIG_LUCI_LANG_zh-cn=y
CONFIG_PACKAGE_luci-theme-design=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_lua=y
CONFIG_PACKAGE_liblua=y
CONFIG_PACKAGE_libubus-lua=y
CONFIG_PACKAGE_libuci-lua=y
CONFIG_PACKAGE_default-settings=y

